
execute store result score random_mob wander.trader_dimension run random value 1..16
$execute if score random_mob wander.trader_dimension matches 1..8 run summon zombie 18 10 $(rand_z_pos) {attributes:[{id:"minecraft:fall_damage_multiplier",base:0.0d}],Motion:[$(rand_x_motion)d,$(rand_y_motion)d,0.0d],Tags:["trader_dimension.chest_mob"],DeathLootTable:"minecraft:empty",drop_chances:{chest:0,head:0,feet:0,legs:0,mainhand:0}}
$execute if score random_mob wander.trader_dimension matches 9..15 run summon skeleton 18 10 $(rand_z_pos) {attributes:[{id:"minecraft:fall_damage_multiplier",base:0.0d}],Motion:[$(rand_x_motion)d,$(rand_y_motion)d,0.0d],Tags:["trader_dimension.chest_mob"],equipment:{mainhand:{count: 1, id: "minecraft:bow"}},DeathLootTable:"minecraft:empty",drop_chances:{chest:0,head:0,feet:0,legs:0,mainhand:0}}
$execute if predicate {"condition":"minecraft:random_chance","chance":0.3} if score random_mob wander.trader_dimension matches 16 run summon creeper 18 10 $(rand_z_pos) {attributes:[{id:"minecraft:fall_damage_multiplier",base:0.0d}],Motion:[$(rand_x_motion)d,$(rand_y_motion)d,0.0d],Tags:["trader_dimension.chest_mob"],DeathLootTable:"minecraft:empty"}
$execute if score bad_omen wander.data matches 1 positioned 18 10 $(rand_z_pos) as @n[type=!creeper,distance=0..0.2,tag=trader_dimension.chest_mob] run function wander:trader_dimension/spawn/random_gear
